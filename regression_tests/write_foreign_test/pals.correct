        ApertureP:
          shape: RECTANGULAR     
          location: EXIT_END        
        BodyShiftP:
          x_offset:   5.0000E-02             
          x_rot:  -1.0000E-03             
          z_rot:   1.0000E-01             
        RFP:
          rf_frequency:   5.0000E+08             
          voltage:   5.0450E+03             
          phi0:  -1.9000E-01             
          num_cells:   1.0000E+01             
          L_active:   4.4969E+00             
          cavity_type: TRAVELING_WAVE      
        BmadP:
          Bmand_key: Lcavity

    - end_b0: 
        kind: Marker
        ApertureP:
          shape: RECTANGULAR     
          location: EXIT_END        

