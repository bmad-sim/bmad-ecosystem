no_digested

parameter[lattice] = "GPU tracking bend with misalignment"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

b1: sbend, L = 1.0, g = 0.5, x_offset = 3e-4, y_offset = -2e-4, ref_tilt = 0.01

lat: line = (b1)

use, lat
