no_digested

parameter[lattice] = "GPU tracking kitchen sink — all parameters"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

! 1. Plain drift (L only)
d_plain: drift, L = 2.0

! 2. Drift with aperture
d_aper: drift, L = 1.5,
    x1_limit = 3e-3, x2_limit = 3e-3,
    y1_limit = 3e-3, y2_limit = 3e-3

! 3. Plain quadrupole (L, k1)
q_plain: quadrupole, L = 0.5, k1 = 0.8

! 4. Quad with misalignment (x_offset, y_offset, tilt)
q_misalign: quadrupole, L = 0.4, k1 = 1.0,
    x_offset = 3e-4, y_offset = -2e-4, tilt = 0.01

! 5. Quad with fringe fields
q_fringe: quadrupole, L = 0.6, k1 = 1.2, fringe_type = full

! 6. Quad with magnetic multipoles (b2 sextupole, a2 skew sext, b3 octupole)
q_mag_multi: quadrupole, L = 0.5, k1 = 0.9,
    b2 = 0.3, a2 = 0.05, b3 = 0.1

! 7. Quad with electric multipoles (a0_elec, b1_elec)
q_elec: quadrupole, L = 0.5, k1 = 1.0,
    a0_elec = 500, b1_elec = 200

! 8. Quad with aperture
q_aper: quadrupole, L = 0.5, k1 = 0.7,
    x1_limit = 3e-3, x2_limit = 3e-3,
    y1_limit = 3e-3, y2_limit = 3e-3

! 9. Everything combined: fringe + misalign + tilt + mag multipoles + elec multipoles + aperture
q_combo: quadrupole, L = 0.5, k1 = 1.0,
    x_offset = 2e-4, y_offset = -1e-4, tilt = 0.005,
    fringe_type = full,
    b2 = 0.2, a2 = 0.03, b3 = 0.08,
    a0_elec = 400, b1_elec = 150,
    x1_limit = 4e-3, x2_limit = 4e-3,
    y1_limit = 4e-3, y2_limit = 4e-3

! 10. Another drift to let the beam propagate
d_mid: drift, L = 1.0

! --- Bends ---

! 11. Plain bend
b_plain: sbend, L = 1.0, g = 0.5

! 12. Bend with k1 (sbend_body_with_k1_map path)
b_k1: sbend, L = 0.8, g = 0.4, k1 = 0.8

! 13. Bend with fringe + misalignment
b_fringe_mis: sbend, L = 0.8, g = 0.3, fringe_type = full,
    x_offset = 2e-4, y_offset = -1e-4, ref_tilt = 0.005

! 14. Bend with magnetic multipoles
b_multi: sbend, L = 1.0, g = 0.5, b2 = 0.3, a2 = 0.05, b3 = 0.1

! --- Lcavities ---

! 15. Plain lcavity (standing wave, with fringe)
lc_plain: lcavity, L = 1.0, rf_frequency = 1e9, gradient = 1e5,
    n_rf_steps = 10

! 16. Lcavity with misalignment + phase offsets
lc_misalign: lcavity, L = 0.8, rf_frequency = 1e9, gradient = 8e4,
    n_rf_steps = 10,
    x_offset = 2e-4, y_offset = -1e-4, tilt = 0.005,
    phi0 = 0.1, phi0_err = -0.05, voltage_err = 5e3

! --- Pipes ---

! 17. Plain pipe (drift-like, no multipoles)
p_plain: pipe, L = 1.5

! 18. Pipe with misalignment
p_misalign: pipe, L = 1.0, x_offset = 3e-4, y_offset = -2e-4, tilt = 0.01

! 19. Pipe with aperture
p_aper: pipe, L = 1.0,
    x1_limit = 4e-3, x2_limit = 4e-3,
    y1_limit = 4e-3, y2_limit = 4e-3

! 20. Pipe with misalignment + aperture (combo)
p_combo: pipe, L = 1.0,
    x_offset = 2e-4, y_offset = -1e-4, tilt = 0.005,
    x1_limit = 4e-3, x2_limit = 4e-3,
    y1_limit = 4e-3, y2_limit = 4e-3

! 21. Final drift
d_final: drift, L = 1.0

lat: line = (d_plain, q_plain, d_aper, q_misalign, q_fringe,
             q_mag_multi, q_elec, q_aper, q_combo, d_mid,
             b_plain, b_k1, b_fringe_mis, b_multi,
             lc_plain, lc_misalign,
             p_plain, p_misalign, p_aper, p_combo,
             d_final)

use, lat
