no_digested

parameter[lattice] = "GPU tracking lcavity with misalignment"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

lc1: lcavity, L = 1.0, rf_frequency = 1e9, gradient = 1e5, n_rf_steps = 10,
    x_offset = 3e-4, y_offset = -2e-4, tilt = 0.01

lat: line = (lc1)

use, lat
