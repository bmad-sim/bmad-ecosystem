no_digested

parameter[lattice] = "GPU tracking bend benchmark"

beginning[beta_a] = 10
beginning[beta_b] = 10
parameter[e_tot] = 10e6
parameter[particle] = electron

parameter[geometry] = open

! 1. Plain bend
b_plain: sbend, L = 1.0, g = 0.5

! 2. Bend with k1 (sbend_body_with_k1_map path)
b_k1: sbend, L = 0.8, g = 0.4, k1 = 0.8

! 3. Bend with fringe
b_fringe: sbend, L = 1.0, g = 0.5, fringe_type = full

! 4. Bend with misalignment
b_misalign: sbend, L = 0.8, g = 0.3, x_offset = 3e-4, y_offset = -2e-4, ref_tilt = 0.01

! 5. Bend with magnetic multipoles
b_multi: sbend, L = 1.0, g = 0.5, b2 = 0.3, a2 = 0.05, b3 = 0.1

! 6. Bend with everything combined
b_combo: sbend, L = 1.0, g = 0.5, k1 = 0.6,
    fringe_type = full,
    x_offset = 2e-4, y_offset = -1e-4, ref_tilt = 0.005,
    b2 = 0.2, a2 = 0.03

lat: line = (b_plain, b_k1, b_fringe, b_misalign, b_multi, b_combo)

use, lat
