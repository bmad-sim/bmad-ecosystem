! Test lattice: Taylor-expanded 3D short-range wake (z_taylor).
!
! Every term h_ab is a constant wake A_k = k*1e15 over z in [-100um, 0]
! (k = term number 1..13), so tracked kicks can be compared against the
! exact analytic leading-sum formulas for grid-aligned particles.

no_digested
parameter[lattice]  = z_taylor_wake
parameter[e_tot]    = 1e9
parameter[particle] = electron
parameter[geometry] = open

beginning[beta_a] = 10
beginning[beta_b] = 10

pt: pipe, L = 1, sr_wake = {
  amp_scale = 1.0,  z_scale = 1.0,  scale_with_length = F,
  z_max = 1.0,
  z_taylor = {
    time_based = F,
    smoothing_sigma = 0,
    w00 = {w = {
      -100e-6 1e15,
      -90e-6 1e15,
      -80e-6 1e15,
      -70e-6 1e15,
      -60e-6 1e15,
      -50e-6 1e15,
      -40e-6 1e15,
      -30e-6 1e15,
      -20e-6 1e15,
      -10e-6 1e15,
      0e-6 1e15,
    }},
    w01 = {w = {
      -100e-6 2e15,
      -90e-6 2e15,
      -80e-6 2e15,
      -70e-6 2e15,
      -60e-6 2e15,
      -50e-6 2e15,
